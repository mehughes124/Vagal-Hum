{
  "manifest_version": 3,
  "name": "Vagal Hum",
  "version": "1.0.0",
  "description": "A simple tone generator to hum along with for vagal tone and parasympathetic reset.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vagal Hum",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["offscreen", "storage"]
}
